#!/bin/bash
set -euo pipefail

# Finds highest compatible FileMaker version in search_path (default: /Applications).
# Prints the full .app path and returns 0 on success, 1 if none found.
_find_fm() {
  local search_path="${1:-/Applications}"
  local version app
  for version in 18 17 16; do
    # Subdirectory install: /Applications/FileMaker Pro {N} Advanced/{name}.app
    app="$search_path/FileMaker Pro $version Advanced/FileMaker Pro $version Advanced.app"
    [ -d "$app" ] && echo "$app" && return 0
    # Flat install: /Applications/FileMaker Pro {N}.app
    app="$search_path/FileMaker Pro $version.app"
    [ -d "$app" ] && echo "$app" && return 0
  done
  return 1
}

_main() {
  local script_dir
  script_dir="$(cd "$(dirname "$0")" && pwd)"
  local fmpsl="$script_dir/../Resources/solution.fmpsl"

  local fm_app
  fm_app=$(_find_fm) || {
    osascript -e 'display alert "No compatible FileMaker version found." message "FileMaker Pro 16, 17, or 18 is required to open this solution."'
    exit 1
  }

  open -a "$fm_app" "$fmpsl"
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  _main "$@"
fi
